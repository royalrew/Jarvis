# Jarvis auto-selects a real provider when an API key exists.
# Use openai, anthropic, mock, or auto.
JARVIS_PROVIDER=auto

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
JARVIS_MODEL=

# Speech-to-text for scroll-button push-to-talk
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TRANSCRIBE_LANGUAGE=sv
OPENAI_TRANSCRIPT_REFINEMENT=true
OPENAI_TRANSCRIPT_REFINER_MODEL=gpt-4.1-mini
JARVIS_TRANSCRIBE_TERMS=

# Personality context
JARVIS_NAME=Jarvis
JARVIS_USER_NAME=Jimmy

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
JARVIS_TELEGRAM_VOICE=true

# Calendar
# Use a private iCal/ICS URL, for example Google Calendar's secret iCal address.
# Multiple calendars can be comma-separated.
JARVIS_CALENDAR_ICS_URL=
