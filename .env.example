# Jarvis auto-selects a real provider when an API key exists.
# Use openai, anthropic, mock, or auto.
JARVIS_PROVIDER=auto

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
JARVIS_MODEL=

# Speech-to-text for scroll-button push-to-talk
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TRANSCRIBE_LANGUAGE=sv
OPENAI_TRANSCRIPT_REFINEMENT=true
OPENAI_TRANSCRIPT_REFINER_MODEL=gpt-4.1-mini
JARVIS_TRANSCRIBE_TERMS=

# Text classification
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini

# Text-to-speech
JARVIS_TTS_MODEL=tts-1
JARVIS_VOICE=onyx

# Personality context
JARVIS_NAME=Jarvis
JARVIS_USER_NAME=Jimmy

# Local storage
# Leave empty for defaults. Railway storage is ephemeral unless you add a volume.
JARVIS_DB_PATH=
JARVIS_NOTES_PATH=

# Trainer app (Postgres)
# Local development can use trainer/docker-compose.yml.
DATABASE_URL=postgres://postgres:postgres@localhost:5434/trainer

# AI image generation for trainer exercise images
# FAL_KEY is the standard fal.ai name; FAL_AI also works in this repo.
FAL_KEY=
FAL_IMAGE_MODEL=fal-ai/flux/schnell

# Proactive desktop checks
JARVIS_PROACTIVE_INTERVAL_MIN=30

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
JARVIS_TELEGRAM_VOICE=true

# Calendar
# Use a private iCal/ICS URL, for example Google Calendar's secret iCal address.
# Multiple calendars can be comma-separated.
JARVIS_CALENDAR_ICS_URL=
JARVIS_CALENDAR_ICS_URLS=
