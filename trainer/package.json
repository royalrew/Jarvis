{
  "name": "jarvis-trainer",
  "version": "0.1.0",
  "private": true,
  "description": "Vägen till flaggan – gamifierad calisthenics-app (del av Jarvis).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx db/seed.ts",
    "images:exercises": "tsx scripts/generate-exercise-images.ts",
    "images:exercises:generate": "tsx scripts/generate-exercise-images.ts --generate"
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.1",
    "drizzle-orm": "^0.38.3",
    "next": "^15.1.6",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
