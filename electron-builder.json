{
  "appId": "local.jarvis.personal",
  "productName": "Jarvis",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "asar": true,
  "win": {
    "signAndEditExecutable": false,
    "target": [
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ],
    "artifactName": "Jarvis-${version}.${ext}"
  }
}
